package com.Reursion.Bactracking;
/**
 * @author _karthick
 * 
 * For each  Queen we need to find its right position we reduce the problem of N Queen into One Queen  
 * 
 *
 */
public class N_Queens {

	public static void main(String[] args) {
		int n=4;
		boolean[][] board = new boolean[n][n];
		solve(board, 0);
	}
	
	static int solve(boolean[][] board,int r) {
		if(r==board.length) {
			display(board);
			return 1;
		}
		
		int count = 0;
		for(int c=0;c<board.length;c++) {
			if(isSafe(board,r,c)) {
				board[r][c]=true;
				count+=solve(board, r+1);
				board[r][c]=false;
			}
		}
		
		return count;
		
	}

	private static boolean isSafe(boolean[][] board, int r, int c) {
		//check vertical row
		for(int i=0;i<r;i++) {//since only the above rows  have the queens
			if(board[i][c]) {
				return false; 
			}
		}
		//check left diagonal
		//get the maximum moves we can make to reach the left column
		int maxLeft = Math.min(r, c);
		for(int i=1;i<=maxLeft;i++) {
			if(board[r-i][c-i]) {
				return false;
			}
		}
		//check The right
		int maxRight = Math.min(r, board.length-1-c);
		for (int i = 1; i <= maxRight; i++) {
			if(board[r-i][c+i]) {
				return false;
			}
			
		}
		
		return true;
	}

	private static void display(boolean[][] board) {
		 for (boolean[] bs : board) {
			for(boolean b : bs) {
				if(b) {
					System.out.print("Q ");
				}
				else {
					System.out.print("X ");
				}
			}
			System.out.println();
		}
	}
}
