public class N_Queens {

	public static void main(String[] args) {
		
	}
	
	static int solve(boolean[][] board,int r) {
		if(r==board.length) {
			display(board);
			return 1;
		}
		
		int count = 0;
		for(int c=0;c<board.length;c++) {
			if(isSafe(board,r,c)) {
				board[r][c]=true;
				count+=solve(board, r+1);
				board[r][c]=false;
			}
		}
		
		return count;
		
	}

