package com.Reursion.Bactracking;

import java.util.ArrayList;
import java.util.List;

public class Maze4 {
	public static void main(String[] args) {
		boolean[][] maze = {
				{true,true,true},
				{true,true,true},
				{true,true,true}
		};
		List<String> ans = allDirections("", maze, 0, 0);
		System.out.println(ans);
	}

	static List<String> allDirections(String p,boolean maze[][], int r, int c) {
//Here to avoid error we can mark the visited the places but it is restricted for other recursive calls so other paths can't be found
		//for the other calls the path should not be false that is not marked
		//so while moving back after the call we need to restore the maze as it was
		//You are making the changes by the below recursion calls when going outside of that call changes that are made by that calls are tracked back
		
		
		if(r==maze.length-1 && c==maze[0].length-1) {
			ArrayList<String> list = new ArrayList<>();
			list.add(p);
			return list;
		}
		
		if(!maze[r][c]) {
			return new ArrayList<String>();
		}
		ArrayList<String> ans = new ArrayList<>();
		if(r<maze.length-1) {
			ans.addAll( allDirections(p+"D", maze, r+1, c));
			
		}
		if(c<maze[0].length-1) {
			ans.addAll( allDirections(p+"R", maze, r, c+1));
		}
		if(c>0) {
			allDirections(p+"L", maze, r, c-1);
		}
		if(r>0) {
			allDirections(p+"U", maze, r-1, c);
			
		}
		
		
		
		
		return ans;
	}
}
